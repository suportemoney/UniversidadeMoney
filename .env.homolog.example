# Homologação (VPS) — copiar para .env.homolog (NÃO commitar)
APP_ENV=homologation
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=trocar-por-chave-segura-homolog

POSTGRES_USER=universidade_user
POSTGRES_PASSWORD=trocar-na-vps
POSTGRES_DB=universidade_money

DB_HOST=db
DB_PORT=5432
DB_NAME=universidade_money_hml
DB_USER=universidade_user
DB_PASSWORD=trocar-na-vps

DOMAIN_INTERNO_HML=interno-hml.moneypromotora.com.br
DOMAIN_PLATAFORMA_HML=plataforma-hml.moneypromotora.com.br
DOMAIN_PAINEL_HML=painel-interno-hml.moneypromotora.com.br

ALLOWED_HOSTS=interno-hml.moneypromotora.com.br,plataforma-hml.moneypromotora.com.br,painel-interno-hml.moneypromotora.com.br
CSRF_TRUSTED_ORIGINS=https://interno-hml.moneypromotora.com.br,https://plataforma-hml.moneypromotora.com.br,https://painel-interno-hml.moneypromotora.com.br
CORS_ALLOWED_ORIGINS=https://interno-hml.moneypromotora.com.br,https://plataforma-hml.moneypromotora.com.br,https://painel-interno-hml.moneypromotora.com.br

STATIC_ROOT=/data/static
MEDIA_ROOT=/data/media
