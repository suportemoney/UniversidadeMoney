# Produção (VPS) — copiar para .env.production (NÃO commitar)
APP_ENV=production
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=trocar-por-chave-segura-na-vps

POSTGRES_USER=universidade_user
POSTGRES_PASSWORD=trocar-na-vps
POSTGRES_DB=universidade_money

DB_HOST=db
DB_PORT=5432
DB_NAME=universidade_money
DB_USER=universidade_user
DB_PASSWORD=trocar-na-vps

DOMAIN_INTERNO=interno.moneypromotora.com.br
DOMAIN_PLATAFORMA=plataforma.moneypromotora.com.br
DOMAIN_PAINEL=painel-interno.moneypromotora.com.br
DOMAIN_INTERNO_HML=interno-hml.moneypromotora.com.br
DOMAIN_PLATAFORMA_HML=plataforma-hml.moneypromotora.com.br
DOMAIN_PAINEL_HML=painel-interno-hml.moneypromotora.com.br
CERTBOT_EMAIL=admin@moneypromotora.com.br

ALLOWED_HOSTS=interno.moneypromotora.com.br,plataforma.moneypromotora.com.br,painel-interno.moneypromotora.com.br
CSRF_TRUSTED_ORIGINS=https://interno.moneypromotora.com.br,https://plataforma.moneypromotora.com.br,https://painel-interno.moneypromotora.com.br
CORS_ALLOWED_ORIGINS=https://interno.moneypromotora.com.br,https://plataforma.moneypromotora.com.br,https://painel-interno.moneypromotora.com.br

STATIC_ROOT=/data/static
MEDIA_ROOT=/data/media
